OPENAI_API_KEY=your_key_here
TITAN_LOG_LEVEL=INFO
TITAN_DEBUG_BRAIN=false
TITAN_LLM_MODEL=gpt-5.2
TITAN_MAX_PROMPT_TOKENS=12000
TITAN_PROMPTS_DIR=prompts
# Phase 9 — Autonomy (defaults: proactive off, confirmations on)
TITAN_AUTONOMY_PROACTIVE=off
TITAN_AUTONOMY_AUTO_TOOLS=false
TITAN_AUTONOMY_CONFIRM_WRITES=true
TITAN_AUTONOMY_CONFIRM_EXEC=true
TITAN_AUTONOMY_MAX_JOBS=10
TITAN_LLM_MODEL_CLASSIFICATION=gpt-5.2
TITAN_LLM_MODEL_AGENT=gpt-5.2
TITAN_LLM_MODEL_EVALUATION=gpt-5.2
# Phase 10A — Tool Runtime V2 (default on; set false for legacy Phase 6 path)
TITAN_TOOL_RUNTIME_V2=true
TITAN_TOOL_RUNTIME_VERSION=0.10.0
TITAN_TOOL_DEFAULT_EXECUTION_MODE=live
TITAN_TOOL_AUDIT_ENABLED=true
TITAN_TOOL_PERSIST_RUNS=false
TITAN_TOOL_PERSIST_METRICS=false
TITAN_TOOL_QUOTA_ENABLED=false
TITAN_TOOL_CONFIRMATION_TTL=300
# Phase 10B — Provider credentials (read only by CredentialManager; never commit real values)
TITAN_BRAVE_SEARCH_API_KEY=
TITAN_WEB_SEARCH_API_KEY=
TITAN_CALENDAR_CLIENT_ID=
TITAN_CALENDAR_CLIENT_SECRET=
# Phase 10B — Provider configuration (non-secret)
TITAN_WEB_SEARCH_ENABLED=true
TITAN_BRAVE_SEARCH_ENABLED=true
TITAN_CALENDAR_ENABLED=true
TITAN_CALENDAR_PROVIDER=mock
# Phase 14.2 — Google Calendar backend (OAuth local)
TITAN_GOOGLE_CALENDAR_ENABLED=false
TITAN_GOOGLE_CLIENT_SECRET_PATH=data/google_client_secret.json
TITAN_GOOGLE_TOKEN_PATH=data/google_calendar_token.json
# Phase 15.2 — Gmail backend (OAuth local)
TITAN_EMAIL_ENABLED=true
TITAN_EMAIL_PROVIDER=mock
TITAN_GMAIL_ENABLED=false
TITAN_GMAIL_CLIENT_SECRET_PATH=data/google_gmail_client_secret.json
TITAN_GMAIL_TOKEN_PATH=data/google_gmail_token.json
# Phase 12.5 — Obsidian connector (existing user vault only; not Titan memory/brain)
# Point TITAN_OBSIDIAN_VAULT_PATH at your existing Obsidian vault folder (e.g. "Titan AI").
# Titan never creates a new vault — it only reads and maintains notes inside this path.
TITAN_OBSIDIAN_ENABLED=false
TITAN_OBSIDIAN_VAULT_PATH=
# Phase 13.2 — Browser connector (Playwright backend; read-only inspection)
TITAN_BROWSER_ENABLED=false
TITAN_BROWSER_TIMEOUT_SECONDS=30
TITAN_BROWSER_HEADLESS=true
# Core Browser Tool V1 — HTTP read-only (core/tools/browser)
TITAN_BROWSER_MAX_DOWNLOAD_SIZE=5242880
TITAN_BROWSER_USER_AGENT=TitanBot/1.0 (Read-Only Browser Tool)
TITAN_BROWSER_FOLLOW_REDIRECTS=true
TITAN_BROWSER_ALLOWED_SCHEMES=http,https
# Python Runtime V1 — sandboxed execution (core/tools/python)
TITAN_TOOL_PYTHON_TIMEOUT=5
TITAN_PYTHON_RUNTIME_TIMEOUT_SECONDS=5
TITAN_PYTHON_RUNTIME_MAX_EXECUTION_SECONDS=5
TITAN_PYTHON_RUNTIME_MAX_OUTPUT_BYTES=65536
TITAN_PYTHON_RUNTIME_MAX_FILE_COUNT=50
# Optional isolated workspace (defaults to system temp /titan_python_runtime)
TITAN_PYTHON_RUNTIME_WORKSPACE=
# Terminal Tool V1 — controlled workspace shell (core/tools/terminal)
# Defaults to PROJECT_ROOT. Dangerous commands are blocked; execution requires confirmation.
TITAN_TERMINAL_TIMEOUT_SECONDS=30
TITAN_TERMINAL_MAX_EXECUTION_SECONDS=120
TITAN_TERMINAL_MAX_OUTPUT_BYTES=65536
TITAN_TERMINAL_WORKSPACE=
# Optional comma-separated allowlist override (defaults: git,pytest,python,npm,uv,...)
TITAN_TERMINAL_ALLOWED_COMMANDS=
# Optional comma-separated blocked substring patterns
TITAN_TERMINAL_BLOCKED_PATTERNS=
# GitHub Tool V1 — read-only repository access (core/tools/github)
# Personal Access Token only — never commit real tokens.
TITAN_GITHUB_TOKEN=
TITAN_GITHUB_ENABLED=true
TITAN_GITHUB_TIMEOUT_SECONDS=30
TITAN_GITHUB_RETRY_COUNT=2
TITAN_GITHUB_PER_PAGE=30
TITAN_GITHUB_API_BASE_URL=https://api.github.com
TITAN_GITHUB_USER_AGENT=TitanBot/1.0 (Read-Only GitHub Tool)
# Phase 16.5 — Apex/Rithmic read-only broker adapter (credential validation only; no live SDK)
TITAN_BROKER_PROVIDER=apex_rithmic
TITAN_BROKER_READ_ONLY=true
TITAN_TRADING_LIVE_ENABLED=false
TITAN_RITHMIC_ENABLED=false
TITAN_RITHMIC_USERNAME=
TITAN_RITHMIC_PASSWORD=
TITAN_RITHMIC_SYSTEM=
TITAN_RITHMIC_SERVER=
TITAN_RITHMIC_APP_NAME=Titan
TITAN_RITHMIC_APP_VERSION=1.0
# Phase 17.1 — Private web app (local only; disabled by default)
# Set TITAN_WEB_ENABLED=true to start with `python main.py web`.
# Or use `python main.py web-dev` for local development without changing .env.
# Or use `python main.py web-remote` for Cloudflare Tunnel access (see docs/REMOTE_ACCESS.md).
TITAN_WEB_ENABLED=false
TITAN_WEB_HOST=127.0.0.1
TITAN_WEB_PORT=8000
TITAN_WEB_REMOTE_PORT=8765
TITAN_WEB_SECRET_KEY=

# Phase 10 — Cloud deployment (Railway is the fixed production provider)
# Local: development. Railway: set TITAN_APP_ENV=production (see docs/RAILWAY_DEPLOYMENT.md).
# Use TITAN_APP_ENV=production with `python main.py web-prod` or container CMD.
TITAN_APP_ENV=development
# Railway injects PORT; Titan also reads TITAN_WEB_PORT. Do not hardcode on Railway.
PORT=
TITAN_PUBLIC_BASE_URL=
TITAN_ALLOWED_HOSTS=
TITAN_CORS_ALLOWED_ORIGINS=
TITAN_AUTH_REQUIRED=
TITAN_COOKIE_SECURE=false
TITAN_DATA_DIR=data
TITAN_MEMORY_DIR=
TITAN_DATABASE_URL=
# Phase 12.1 — Durable web conversations (Postgres on Railway via DATABASE_URL;
# local/dev falls back to SQLite at data/conversations.db when URL is empty).
# Alias: DATABASE_URL (Railway Postgres plugin).
TITAN_CONVERSATION_PERSISTENCE_ENABLED=true
# Required in production/staging by default — /ready fails if DB unreachable.
TITAN_CONVERSATION_PERSISTENCE_REQUIRED=
TITAN_CONVERSATION_CONTEXT_MAX_TOKENS=3000
TITAN_CONVERSATION_STREAM_ENABLED=true
TITAN_LOG_LEVEL=INFO
# Phase 10.3 — Private production authentication (session cookies)
# NEVER put a plaintext password in this file or in Git.
# Generate a hash locally: python scripts/generate_titan_password_hash.py
# Then set these in Railway Variables only:
#   AUTH_REQUIRED=true
#   TITAN_AUTH_USERNAME=
#   TITAN_AUTH_PASSWORD_HASH=
#   TITAN_SESSION_IDLE_MINUTES=60
#   TITAN_SESSION_MAX_HOURS=24
# Optional second authorized user (e.g. Ibrahim) without rewrite:
#   TITAN_AUTH_USERNAME_2=
#   TITAN_AUTH_PASSWORD_HASH_2=
TITAN_AUTH_USERNAME=
TITAN_AUTH_PASSWORD_HASH=
TITAN_AUTH_USERNAME_2=
TITAN_AUTH_PASSWORD_HASH_2=
TITAN_SESSION_IDLE_MINUTES=60
TITAN_SESSION_MAX_HOURS=24
# Aliases accepted: APP_ENV, HOST, SESSION_SECRET, PUBLIC_BASE_URL, ALLOWED_HOSTS,
# CORS_ALLOWED_ORIGINS, AUTH_REQUIRED, COOKIE_SECURE, DATABASE_URL, OBSIDIAN_VAULT_PATH,
# BROWSER_TOOL_ENABLED, VOICE_RUNTIME_ENABLED, TRADING_RUNTIME_ENABLED, LOG_LEVEL
# Railway template examples (set in Railway Variables UI, not in this file):
#   TITAN_PUBLIC_BASE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
#   TITAN_ALLOWED_HOSTS=${{RAILWAY_PUBLIC_DOMAIN}},healthcheck.railway.app
#   TITAN_CORS_ALLOWED_ORIGINS=https://${{RAILWAY_PUBLIC_DOMAIN}}

# Phase 17.8 — Voice interface (browser STT/TTS + Voice Runtime V1)
TITAN_VOICE_ENABLED=true
TITAN_VOICE_LOCALE=fr-FR
TITAN_VOICE_CONTINUOUS=false
TITAN_VOICE_TTS_RATE=0.95
TITAN_VOICE_TTS_PITCH=1.0
TITAN_VOICE_VOLUME=1.0
TITAN_VOICE_VOICE=default
TITAN_VOICE_STT_PROVIDER=mock
TITAN_VOICE_TTS_PROVIDER=mock
TITAN_VOICE_MICROPHONE=default
TITAN_VOICE_SPEAKER=default
TITAN_VOICE_SILENCE_TIMEOUT=2.0
TITAN_VOICE_CONVERSATION_MODE=single_shot
TITAN_VOICE_SESSIONS_PATH=data/voice_sessions.json
