OPENAI_API_KEY=your_key_here
TITAN_LOG_LEVEL=INFO
TITAN_DEBUG_BRAIN=false
TITAN_LLM_MODEL=gpt-5.2
TITAN_MAX_PROMPT_TOKENS=12000
TITAN_PROMPTS_DIR=prompts
# Phase 9 — Autonomy (defaults: proactive off, confirmations on)
TITAN_AUTONOMY_PROACTIVE=off
TITAN_AUTONOMY_AUTO_TOOLS=false
TITAN_AUTONOMY_CONFIRM_WRITES=true
TITAN_AUTONOMY_CONFIRM_EXEC=true
TITAN_AUTONOMY_MAX_JOBS=10
TITAN_LLM_MODEL_CLASSIFICATION=gpt-5.2
TITAN_LLM_MODEL_AGENT=gpt-5.2
TITAN_LLM_MODEL_EVALUATION=gpt-5.2
# Phase 10A — Tool Runtime V2 (default on; set false for legacy Phase 6 path)
TITAN_TOOL_RUNTIME_V2=true
TITAN_TOOL_RUNTIME_VERSION=0.10.0
TITAN_TOOL_DEFAULT_EXECUTION_MODE=live
TITAN_TOOL_AUDIT_ENABLED=true
TITAN_TOOL_PERSIST_RUNS=false
TITAN_TOOL_PERSIST_METRICS=false
TITAN_TOOL_QUOTA_ENABLED=false
TITAN_TOOL_CONFIRMATION_TTL=300
